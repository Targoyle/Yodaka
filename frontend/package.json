    "@vitejs/plugin-react": "^4.3.1",
    "eslint": "^10.4.0",
    "eslint-plugin-no-unsanitized": "^4.1.5",
    "fake-indexeddb": "^6.2.5",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "vite-plugin-top-level-await": "^1.4.4",
